{
  "expo": {
    "name": "StoopingClubApp",
    "slug": "StoopingClubApp",
    "scheme": ["stoopingclubapp", "shop.74832183474.app"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/stoopingclublogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F4EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stoopingclub.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Stooping Club sends Friday order reminders and Sunday pickup reminders.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["stoopingclubapp", "shop.74832183474.app"]
          }
        ]
      },
      "splash": {
        "image": "./assets/stoopingclublogo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F7F4EE"
      }
    },
    "android": {
      "package": "com.stoopingclub.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "splash": {
        "image": "./assets/stoopingclublogo.png",
        "resizeMode": "contain",
        "backgroundColor": "#F7F4EE"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "data": [
            {
              "scheme": "shop.74832183474.app",
              "host": "account",
              "pathPrefix": "/callback"
            },
            {
              "scheme": "stoopingclubapp",
              "host": "account",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/stoopingclublogo.png",
          "resizeMode": "contain",
          "backgroundColor": "#F7F4EE",
          "imageWidth": 300
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3B6D11"
        }
      ],
      "expo-web-browser"
    ]
  }
}
